public class FibonacciProgram {

    public static void fibonacci(Integer num) {

        Integer a = 0;
        Integer b = 1;
        Integer c;

        System.debug(a);
        System.debug(b);

        for(Integer i = 2; i < num; i++) {

            c = a + b;

            System.debug(c);

            a = b;
            b = c;
        }
    }
}

